[flake8]
max-line-length = 120
exclude =
    .git,
    __pycache__,
    venv,
    migrations,
    .venv,
    .env,
    *.egg-info,
    .idea,
    .pytest_cache,
    .coverage,
    htmlcov,
    dist,
    build

ignore =
    E203,
    W503,
    E501

per-file-ignores =
    __init__.py:F401,
    tests.py:F401,E302,E305
    test_*.py:F401,E302,E305,F403,F405
